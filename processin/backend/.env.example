# Copy this file to .env and fill in values before running in production.

# Required: random secret key for JWT signing (min 32 chars)
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace-with-a-random-secret-key

# Comma-separated list of allowed frontend origins
# Dev default: http://localhost:5173,http://127.0.0.1:5173
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
